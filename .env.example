# ─── Zoom API Credentials ────────────────────────────────────────────────────
# Obtained from https://marketplace.zoom.us → Your App → App Credentials
# Zoom uses OAuth 2.0 Server-to-Server auth (no user login required).

# In Node.js we use dotenv to load a .env file into process.env at startup,
# then wrap it in a typed config object (Options pattern) — see ZoomOptions.ts.
ZOOM_ACCOUNT_ID=your_account_id_here
ZOOM_CLIENT_ID=your_client_id_here
ZOOM_CLIENT_SECRET=your_client_secret_here

ZOOM_SECRET_TOKEN=your_secret_token_here

ZOOM_BASE_URL=https://api.zoom.us/v2
ZOOM_OAUTH_URL=https://zoom.us/oauth/token

# The Zoom user whose meetings will be managed.
# 'me' = the authenticated app user (most common for Server-to-Server OAuth).
ZOOM_TARGET_USER_ID=me

# ─── Server Config ───────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Logging Config ──────────────────────────────────────────────────────────
# Log level for Pino. Valid values: trace, debug, info, warn, error, fatal.
# Default is 'info'. Equivalent to Serilog's MinimumLevel.
LOG_LEVEL=info
